<UserControl x:Class="DSInternals.Win32.WebAuthn.PasskeyUI.AuthenticatorPresetMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="PresetMenuControl">
    <Menu VerticalAlignment="Center" Background="Transparent">
        <MenuItem Header="Load authenticator preset..." ItemsSource="{Binding KnownPresets, ElementName=PresetMenuControl}">
            <MenuItem.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Header" Value="{Binding Name}" />
                    <Setter Property="Command" Value="{Binding InternalSelectCommand, ElementName=PresetMenuControl}" />
                    <Setter Property="CommandParameter" Value="{Binding}" />
                </Style>
            </MenuItem.ItemContainerStyle>
        </MenuItem>
    </Menu>
</UserControl>

<UserControl x:Class="DSInternals.Win32.WebAuthn.PasskeyUI.AssertionOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DSInternals.Win32.WebAuthn.PasskeyUI"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="1250">
    <GroupBox Header="Assertion Options">
        <DockPanel>
            <UniformGrid Rows="1" DockPanel.Dock="Top">
                <DockPanel>
                    <Label Name="RpIdLabel" Content="Relying party:" Width="130" VerticalAlignment="Center" />
                    <TextBox x:Name="RpIdTextBox" VerticalAlignment="Center" TabIndex="0">
                        <TextBox.Text>
                            <Binding Path="RelyingPartyId" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <local:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                </DockPanel>
                <DockPanel>
                    <Label x:Name="AppIdLabel" Content="U2F AppID:" VerticalAlignment="Center" />
                    <TextBox x:Name="AppIdTextBox" Text="{Binding AppId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" ToolTip="Legacy U2F application identifier" TabIndex="1" />
                </DockPanel>
            </UniformGrid>
            <DockPanel DockPanel.Dock="Top">
                <Label Name="AuthenticatorAttachmentLabel" Content="Authenticator:" Width="130" VerticalAlignment="Center" />
                <ComboBox x:Name="AuthenticatorAttachmentComboBox" ItemsSource="{Binding AuthenticatorAttachments, Mode=OneTime}" SelectedValue="{Binding AuthenticatorAttachment, Mode=TwoWay}" DisplayMemberPath="Value" SelectedValuePath="Key" Width="160" VerticalAlignment="Center" TabIndex="2" />
                <Label Name="CredentialHintLabel" Content="Credential hint:" VerticalAlignment="Center" Margin="20,0,0,0" />
                <ComboBox Name="CredentialHintComboBox" ItemsSource="{Binding CredentialHints, Mode=OneTime}" SelectedValue="{Binding CredentialHint, Mode=TwoWay}" DisplayMemberPath="Value" SelectedValuePath="Key" VerticalAlignment="Center" Width="120" TabIndex="3" />
                <Label Name="RemoteWebOriginLabel" Content="Remote web origin:" VerticalAlignment="Center" Margin="20,0,0,0" />
                <TextBox Name="RemoteWebOriginTextBox" Text="{Binding RemoteWebOrigin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" TabIndex="4" ToolTip="Optional remote web origin for cross-device WebAuthn operations" />
            </DockPanel>
            <DockPanel DockPanel.Dock="Top">
                <Label Name="UserVerificationLabel" Content="User verification:" Width="130" VerticalAlignment="Center" />
                <ComboBox x:Name="UserVerificationComboBox" ItemsSource="{Binding UserVerificationRequirements, Mode=OneTime}" SelectedValue="{Binding UserVerificationRequirement, Mode=TwoWay}" DisplayMemberPath="Value" SelectedValuePath="Key" Width="130" VerticalAlignment="Center" TabIndex="5" />
                <Label Name="LargeBlobOperationLabel" Content="Large blob operation:" VerticalAlignment="Center" />
                <ComboBox x:Name="LargelobperationComboBox" ItemsSource="{Binding LargeBlobOperations, Mode=OneTime}" SelectedValue="{Binding LargeBlobOperation, Mode=TwoWay}" DisplayMemberPath="Value" SelectedValuePath="Key" Width="90" VerticalAlignment="Center" TabIndex="6" />
                <CheckBox Name="GetCredBlobCheckBox" Content="Get credential blob" IsChecked="{Binding GetCredentialBlob, Mode=TwoWay}" VerticalAlignment="Center" TabIndex="7" />
                <CheckBox Name="IsBrowserPrivateModeCheckBox" IsChecked="{Binding IsBrowserPrivateMode, Mode=TwoWay}" Content="Browser in private mode" VerticalAlignment="Center" TabIndex="8" />
                <Button Name="GenerateChallengeButton" Content="Generate challenge" VerticalAlignment="Center" Command="{Binding GenerateChallengeCommand}" DockPanel.Dock="Right" TabIndex="10" />
                <Label Name="TimeoutLabel" Content="Timeout:" VerticalAlignment="Center" />
                <local:TimeoutEditor x:Name="TimeoutEditor" Timeout="{Binding Timeout, Mode=TwoWay}" VerticalAlignment="Center" TabIndex="9" />
            </DockPanel>
            <UniformGrid Rows="1" DockPanel.Dock="Bottom">
                <DockPanel>
                    <Label Name="HmacSecretSalt1Label" Content="HMAC secret salt 1:" VerticalAlignment="Center" Width="130" DockPanel.Dock="Left" />
                    <Button Name="GenerateHmacSecretSalt1Button" Content="Generate" Command="{Binding GenerateHmacSecretSalt1Command}" ToolTip="Generate random HMAC secret salt 1" VerticalAlignment="Center" DockPanel.Dock="Right" TabIndex="14" />
                    <TextBox x:Name="HmacSecretSalt1TextBox" VerticalAlignment="Center" TabIndex="13" MaxLength="{Binding HmacSecretSaltStringLength, Mode=OneTime}" ToolTip="System-specific 32-byte salt in Base16 encoding">
                        <TextBox.Text>
                            <Binding Path="HmacSecretSalt1String" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <ExceptionValidationRule />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                </DockPanel>
                <DockPanel>
                    <Label Name="HmacSecretSalt2Label" Content="HMAC secret salt 2:" VerticalAlignment="Center" DockPanel.Dock="Left" />
                    <Button Name="GenerateHmacSecretSalt2Button" Content="Generate" Command="{Binding GenerateHmacSecretSalt2Command}" ToolTip="Generate random HMAC secret salt 2" VerticalAlignment="Center" DockPanel.Dock="Right" TabIndex="16" />
                    <TextBox x:Name="HmacSecretSalt2TextBox" VerticalAlignment="Center" TabIndex="15" MaxLength="{Binding HmacSecretSaltStringLength, Mode=OneTime}" ToolTip="Optional system-specific 32-byte salt in Base16 encoding">
                        <TextBox.Text>
                            <Binding Path="HmacSecretSalt2String" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <ExceptionValidationRule />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                </DockPanel>
            </UniformGrid>
            <UniformGrid Columns="1">
                <DockPanel>
                    <Label Name="ChallengeLabel" Content="Challenge:" Width="130" />
                    <TextBox x:Name="ChallengeTextBox" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="100" ToolTip="Random challenge in Base64url encoding" TabIndex="11">
                        <TextBox.Text>
                            <Binding Path="ChallengeString" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <local:NotEmptyValidationRule ValidatesOnTargetUpdated="True" />
                                    <ExceptionValidationRule />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                </DockPanel>
                <DockPanel>
                    <Label Name="LargeBlobLabel" Content="Large blob:" Width="130" />
                    <TextBox x:Name="LargeBlobTextBox" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="100" TabIndex="12">
                        <TextBox.Text>
                            <Binding Path="LargeBlobString" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <ExceptionValidationRule />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                </DockPanel>
            </UniformGrid>
        </DockPanel>
    </GroupBox>
</UserControl>
